{
  "definitions": [
    {
      "title": "Wizard",
      "id": "wizard",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/fd/components/form/panelcontainer/v1/panelcontainer",
            "template": {
              "jcr:title": "Wizard",
              "fieldType": "panel",
              "fd:viewType": "wizard",
              "minOccur": 1,
              "panel1": {
                "jcr:title": "Item 1",
                "fieldType": "panel",
                "sling:resourceType": "core/fd/components/form/panelcontainer/v1/panelcontainer"
              },
              "panel2": {
                "jcr:title": "Item 2",
                "fieldType": "panel",
                "sling:resourceType": "core/fd/components/form/panelcontainer/v1/panelcontainer"
              }
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "wizard",
      "fields": [
        {
          "component": "tab",
          "label": "Basic",
          "name": "basic"
        },
        {
          "...": "../../models/form-common/_basic-input-fields.json#/fields"
        },
        {
          "component": "select",
          "name": "variant",
          "label": "Variant",
          "valueType": "string",
          "value": "default",
          "options": [
            { "name": "Default (Back + Next)", "value": "default" },
            { "name": "Continue Only", "value": "continueOnly" }
          ]
        },
        {
          "component": "text",
          "name": "prevButtonLabel",
          "label": "Back Button Label",
          "valueType": "string",
          "value": "Back",
          "condition": { "!==": [{ "var": "variant" }, "continueOnly"] }
        },
        {
          "component": "text",
          "name": "nextButtonLabel",
          "label": "Next Button Label",
          "valueType": "string",
          "value": "Next",
          "condition": { "!==": [{ "var": "variant" }, "continueOnly"] }
        },
        {
          "component": "text",
          "name": "continueButtonLabel",
          "label": "Continue Button Label",
          "valueType": "string",
          "value": "Continue",
          "condition": { "===": [{ "var": "variant" }, "continueOnly"] }
        },
        {
          "...": "../../models/form-common/_help-container.json#/fields"
        }
      ]
    }
  ]
}
